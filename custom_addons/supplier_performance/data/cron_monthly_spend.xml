<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_monthly_spend" model="ir.cron">
        <field name="name">Monthly Supplier Spend</field>

        <field name="model_id" ref="model_supplier_monthly_spend"/>
        <field name="state">code</field>
        <field name="code">model.compute_monthly_spend()</field>

        <!-- Run daily (safe) -->
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>

        <field name="active">True</field>

        <!-- First run -->
        <field name="nextcall">2026-04-08 08:00:00</field>

    </record>

</odoo>