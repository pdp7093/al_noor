<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="payment_provider_payu" model="payment.provider">
        <field name="name">PayU</field>
        <field name="code">payu</field>
        <field name="image_128" type="base64" file="odoo_payment_payu/static/description/icon.png"/>
        <field name="module_id" ref="base.module_odoo_payment_payu" />
        <!-- Todo: For remaining Payment mode codes -->
        <field name="payment_method_ids"
               eval="[Command.set([
                        ref('payment.payment_method_netbanking'),
                        ref('payment.payment_method_card'),
                        ref('payment.payment_method_upi'),
                        ref('payment.payment_method_emi_india'),
                        ref('payment.payment_method_wallets_india'),
                        ref('payment.payment_method_paylater_india'),
                     ])]"
        />
    </record>

</odoo>
