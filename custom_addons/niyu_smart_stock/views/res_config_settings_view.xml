<odoo>
    <record id="res_config_settings_view_form_niyu" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.niyu</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='warehouse_setting_container']" position="after">
                <h2>Niyu AI Configuration</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <label for="niyu_license_key"/>
                            <div class="text-muted">
                                Enter your SaaS License Key from niyulabs.com
                            </div>
                            <field name="niyu_license_key"/>
                            <div class="mt8">
                                <button name="%(niyu_smart_stock.action_niyu_start_sync)d"
                                        string="Run Initial Sync"
                                        type="action"
                                        class="btn-primary icon-link"/>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <label for="niyu_plan_tier" string="Latest Subscription Snapshot"/>
                            <div class="text-muted">
                                Updated from the latest quota or status snapshot received during a forecast run.
                            </div>
                            <div class="row mt16">
                                <div class="col-12 col-md-6">
                                    <table class="table table-sm mb-0">
                                        <tbody>
                                            <tr>
                                                <td class="text-muted">Tier</td>
                                                <td><field name="niyu_plan_tier" readonly="1" nolabel="1"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">SKU Limit</td>
                                                <td><field name="niyu_plan_sku_limit" readonly="1" nolabel="1"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Manual Refresh Max / Day</td>
                                                <td><field name="niyu_plan_manual_limit" readonly="1" nolabel="1"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Auto Refresh Max / Day</td>
                                                <td><field name="niyu_plan_scheduled_limit" readonly="1" nolabel="1"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="col-12 col-md-6">
                                    <table class="table table-sm mb-0">
                                        <tbody>
                                            <tr>
                                                <td class="text-muted">Max Forecast Horizon (Days)</td>
                                                <td><field name="niyu_plan_max_horizon_days" readonly="1" nolabel="1"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Backend Model</td>
                                                <td><field name="niyu_plan_model_type" readonly="1" nolabel="1"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Backend Snapshot Time</td>
                                                <td><field name="niyu_backend_last_seen" readonly="1" nolabel="1"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
