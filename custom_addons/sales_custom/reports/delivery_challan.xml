<odoo>
    <template id="report_delivery_challan">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure" />
                        <h2 style="text-align:center; margin-bottom: 20px;">Delivery Challan</h2>

                        <div class="row">
                            <div class="col-6">
                                <strong>Customer:</strong>
                                <span t-field="o.partner_id.name" />
                                <br />
                                <strong>Address:</strong>
                                <div t-field="o.partner_id"
                                    t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}' />
                            </div>
                            <div class="col-6 text-end">
                                <strong>Order:</strong>
                                <span t-field="o.origin" />
                                <br />
                                <strong>Date:</strong>
                                <span t-field="o.scheduled_date" t-options='{"widget": "date"}' />
                                <br />
                                <strong>Driver:</strong>
                                <span t-field="o.driver_name" />
                            </div>
                        </div>

                        <br />

                        <table class="table table-sm mt-4">
                            <thead>
                                <tr>
                                    <th class="text-start">Product</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Unit</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.move_ids" t-as="line">
                                    <tr>
                                        <td>
                                            <span t-field="line.product_id.display_name" />
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.product_uom_qty" />
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.product_uom.name" />
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <br />
                        <br />

                        <div class="row mt-5">
                            <div class="col-4 offset-8 text-center">
                                <p style="border-top: 1px solid black;">Authorized Signature</p>
                            </div>
                        </div>
                        <div class="oe_structure" />
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_delivery_challan" model="ir.actions.report">
        <field name="name">Delivery Challan</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sales_custom.report_delivery_challan</field>
        <field name="report_file">sales_custom.report_delivery_challan</field>
        <field name="print_report_name">'Delivery Challan - %s' % (object.name)</field>
        <field name="binding_model_id" ref="stock.model_stock_picking" />
        <field name="binding_type">report</field>
    </record>
</odoo>