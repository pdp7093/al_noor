<odoo>
    <data noupdate="1">

        <record id="cron_low_stock_check" model="ir.cron">
            <field name="name">Inventory: Low Stock Email Alert</field>
            <field name="model_id" ref="model_stock_warehouse_orderpoint" />
            <field name="state">code</field>
            <field name="code">model.cron_low_stock_alert()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True" />
        </record>

        <record id="ir_cron_daily_stock_report" model="ir.cron">
            <field name="name">Daily Stock Report</field>

            <!-- Model -->
            <field name="model_id" ref="model_stock_report_scheduler" />

            <!-- Method -->
            <field name="state">code</field>
            <field name="code">model.action_send_daily_report()</field>

            <!-- Run daily -->
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            
            <!-- Active -->
            <field name="active">True</field>

            <!-- 8 AM -->
            <field name="nextcall">2026-04-08 08:00:00</field>

        </record>
    </data>
</odoo>